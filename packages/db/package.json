{
  "name": "@questlog/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "db:generate": "bun --bun drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bun --bun drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "bun --bun drizzle-kit push --config drizzle.config.ts",
    "db:studio": "bun --bun drizzle-kit studio --config drizzle.config.ts"
  },
  "dependencies": {
    "@questlog/contracts": "workspace:*",
    "@questlog/telemetry": "workspace:*",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/pg": "^8.15.6",
    "drizzle-kit": "^0.31.9"
  }
}
