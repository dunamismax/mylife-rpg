{
  "name": "questlog",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @questlog/web dev",
    "build": "bun run --filter @questlog/web build",
    "preview": "bun run --filter @questlog/web preview",
    "test": "bun run --filter @questlog/server test && bun run --filter @questlog/web test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "db:generate": "bun run --filter @questlog/db db:generate",
    "db:migrate": "bun run --filter @questlog/db db:migrate",
    "db:push": "bun run --filter @questlog/db db:push",
    "db:studio": "bun run --filter @questlog/db db:studio",
    "auth:generate": "bun run --filter @questlog/server auth:generate"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5"
  },
  "trustedDependencies": [
    "esbuild",
    "lightningcss"
  ]
}
